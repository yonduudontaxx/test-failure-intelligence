{
  "name": "test-failure-intelligence-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src tests --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=tests/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=tests/integration --passWithNoTests --runInBand",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down 1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^4.4.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "http-errors": "^2.0.1",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "jest": "^29.7.0",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
